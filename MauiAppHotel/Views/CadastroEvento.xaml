<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.CadastroEvento"
             Title=""
             BackgroundColor="#F5F0E8" >

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Cadastro de Evento"
                FontFamily="Cinzel"
                FontSize="26"
                HorizontalOptions="Center"
                TextColor="#D4AF37"/>

            <Entry
                Placeholder="Nome do Evento"
                Text="{Binding NomeEvento}" />

            <DatePicker
                x:Name="dtpck_inicio"
                Date="{Binding DataInicio}" />

            <DatePicker
                x:Name="dtpck_termino"
                Date="{Binding DataTermino}" />

            <Entry
                Placeholder="Número de Participantes"
                Keyboard="Numeric"
                Text="{Binding NumeroParticipantes}" />

            <Entry
                Placeholder="Local do Evento"
                Text="{Binding LocalEvento}" />

            <Entry
                Placeholder="Custo por Participante"
                Keyboard="Numeric"
                Text="{Binding CustoPorParticipante}" />

            <Button
                Text="Finalizar Cadastro"
                Clicked="Button_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
