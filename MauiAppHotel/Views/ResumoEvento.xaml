<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ResumoEvento"
             Title=""
             BackgroundColor="#F5F0E8">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="12">

            <Label
                Text="Resumo do Evento"
                FontSize="26"
                FontFamily="Cinzel"
                HorizontalOptions="Center"
                TextColor="#D4AF37"/>

            <Label Text="{Binding NomeEvento, StringFormat='Evento: {0}'}"
                   TextColor="#800020" />
            <Label Text="{Binding DataInicio, StringFormat='Data de Início: {0:dd/MM/yyyy}'}"
                   TextColor="#800020" />
            <Label Text="{Binding DataTermino, StringFormat='Data de Término: {0:dd/MM/yyyy}'}"
                   TextColor="#800020" />
            <Label Text="{Binding NumeroParticipantes, StringFormat='Participantes: {0}'}"
                   TextColor="#800020" />
            <Label Text="{Binding LocalEvento, StringFormat='Local: {0}'}"
            TextColor="#800020" />
            <Label Text="{Binding CustoPorParticipante, StringFormat='Custo por Participante: R$ {0:F2}'}"
            TextColor="#800020" />
            <Label Text="{Binding Duracao.Days, StringFormat='Duração: {0} dias'}"
                   TextColor="#800020" />

            <Label
                Text="{Binding CustoTotal, StringFormat='Custo Total: R$ {0:F2}'}"
                HorizontalOptions="Center"
                FontFamily="Cinzel"
                FontSize="20"
                TextColor="#D4AF37" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>