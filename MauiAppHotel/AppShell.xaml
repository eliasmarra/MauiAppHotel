<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiAppHotel.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiAppHotel"
    xmlns:Views="clr-namespace:MauiAppHotel.Views"
    Title="MauiAppHotel">

    <FlyoutItem Title="Hotel">
        <ShellContent
        Title="Hospedagem"
        ContentTemplate="{DataTemplate Views:ContratacaoHospedagem}"
        />
    </FlyoutItem>

    <FlyoutItem Title="Eventos">
        <ShellContent
      Title="Cadastro de Evento"
      ContentTemplate="{DataTemplate Views:CadastroEvento}"
      />
    </FlyoutItem>


</Shell>
